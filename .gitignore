# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# === 專案安全性排除 (Project Security Exclusions) ===

# Android 簽名金鑰 — 絕對不能上雲端 (Signing keys — never commit)
android/key.properties
keystore/
*.jks
*.keystore

# 原生 .so 函式庫 — 體積過大且含機敏 Haskell runtime
# Native .so libraries — too large and contains sensitive Haskell runtime
android/app/src/main/jniLibs/
*.so

# Hive 加密資料庫 — 含使用者金鑰與對話紀錄
# Hive encrypted DB — contains user keys and chat history
*.hive

# 環境變數與密碼設定
.env
.env.*
secrets/

# 已產生的程式碼備份 (Generated code backups)
*.dart_temp
*.g.dart.bak
